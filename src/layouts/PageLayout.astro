---
import Head from "@components/Head.astro";
import Header from "@components/Header.astro";
import { SITE } from "@consts";

type Props = {
    title: string;
    description: string;
    lang?: string;
};

const { title, description, lang = "en" } = Astro.props;
---

<!doctype html>
<html lang={lang}>
    <head>
        <Head title={`${title} | ${SITE.NAME}`} description={description} />
    </head>
    <body>
        <Header />
        <main>
            <slot />
        </main>
    </body>
</html>
